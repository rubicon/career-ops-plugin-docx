    "type": "git",
    "url": "git+https://github.com/rubicon/career-ops-plugin-docx.git"
  },
  "bugs": {
    "url": "https://github.com/rubicon/career-ops-plugin-docx/issues"
  },
  "keywords": [
    "career-ops",
    "career-ops-plugin",
    "docx",
    "word",
    "resume",
    "cv",
    "ats"
  ],
  "type": "module",
  "engines": {
